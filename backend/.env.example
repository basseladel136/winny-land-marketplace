APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# SECURITY: Set to the email address of the single admin user.
# Only this email will receive the 'admin' role on login/registration.
ADMIN_EMAIL=

# Frontend SPA URL — used in CORS configuration and email verification links.
FRONTEND_URL=http://localhost:5173

# LOG_LEVEL: use 'debug' in development, 'error' or 'warning' in production.
# WARNING: debug level can expose sensitive request data, passwords, and tokens.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=winny_land
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
# SECURITY: Enable session encryption in production.
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# SECURITY: Token lifetime in minutes. 43200 = 30 days.
# Set lower (e.g. 1440 = 24 h) for higher-security environments.
SANCTUM_TOKEN_EXPIRATION=43200
# Token prefix helps GitHub/GitLab secret scanning auto-detect committed tokens.
SANCTUM_TOKEN_PREFIX=wl_

VITE_APP_NAME="${APP_NAME}"
